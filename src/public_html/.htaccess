RewriteEngine On
# Tell Apache that rewrites happen relative to the /funkphp/ URL path
RewriteBase /funkphp/

# The static asset guardrail
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route everything else safely to index.php
RewriteRule ^(.*)$ index.php [L,QSA]